// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  campaigns     Campaign[]
}

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  niche     String
  location  String
  count     Int
  status    String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId   String   @db.ObjectId
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  businessName String
  category     String?
  webUrl       String?
  email        String?
  phone        String?
  address      String?
  mapsLink     String?
  rating       Float?
  reviewCount  Int?
  source       String?

  // GMB Specifics
  isClaimed       Boolean @default(true)
  hasGmbPhotos    Boolean @default(true)
  isGmbOptimized  Boolean @default(true)
  hasLowRating    Boolean @default(false)

  audit        WebsiteAudit?
  report       LeadReport?
  
  priority     String   @default("COLD") // HOT, WARM, COLD
  priorityScore Int     @default(0)
  priorityReason String?
  
  status       String   @default("PENDING") // PENDING, AUDITING, REPORTING, DONE, FAILED
  slug         String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WebsiteAudit {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId       String   @unique @db.ObjectId
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Technical Data
  title            String?
  metaDescription  String?
  h1Count          Int?
  h2Count          Int?
  hasSsl           Boolean @default(false)
  hasContactForm   Boolean @default(false)
  hasCta           Boolean @default(false)
  hasSchema        Boolean @default(false)
  hasSocialLinks   Boolean @default(false)
  hasReviews       Boolean @default(false)
  
  // Scores
  seoScore        Int @default(0)
  croScore        Int @default(0)
  trustScore      Int @default(0)
  technicalScore  Int @default(0)
  localSeoScore   Int @default(0)
  overallScore    Int @default(0)
  loadTimeMs      Int @default(0)
  isOutdatedUI    Boolean @default(false)

  rawDataJson     Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadReport {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId       String   @unique @db.ObjectId
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  summary      String?
  topGaps      Json?    // Array of strings
  whyGapsMatter String?
  recommendedFixes String?
  
  // AI Service Offer
  serviceOffer Json?    // { type: string, problem: string, solution: string, impact: string, price: string }
  
  outreachAngle String?
  coldEmail     String?
  followUpEmail String?
  shortDm       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
